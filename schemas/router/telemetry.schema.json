{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbasis.internal/schemas/router/telemetry.schema.json",
  "title": "RouterTelemetryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "mission",
    "seed",
    "stage",
    "step",
    "attempt",
    "callKind",
    "configId",
    "provider",
    "model",
    "deploymentKey",
    "deploymentHash",
    "tokensIn",
    "tokensOut",
    "tokensReasoning",
    "cachedTokens",
    "latencyMs",
    "costUsd",
    "outcome",
    "qualitySignals",
    "traceId",
    "responseIdHash",
    "recordedAt",
    "hash"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": ["string", "null"] },
    "mission": { "type": ["string", "null"] },
    "seed": { "type": ["number", "null"] },
    "stage": { "enum": ["S1", "S2", "S3", "S4", "S5", "S6", "S7", "S8", "S9"] },
    "step": { "type": ["string", "number", "null"] },
    "attempt": { "type": "number", "minimum": 1 },
    "callKind": { "type": "string", "minLength": 1 },
    "configId": { "type": ["string", "null"] },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "deploymentKey": { "type": ["string", "null"] },
    "deploymentHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "tokensIn": { "type": "number", "minimum": 0 },
    "tokensOut": { "type": "number", "minimum": 0 },
    "tokensReasoning": { "type": "number", "minimum": 0 },
    "cachedTokens": { "type": "number", "minimum": 0 },
    "latencyMs": { "type": "number", "minimum": 0 },
    "costUsd": { "type": "number", "minimum": 0 },
    "outcome": { "enum": ["accepted", "retried", "rejected", "error", "skipped"] },
    "qualitySignals": { "type": "object" },
    "traceId": { "type": ["string", "null"] },
    "responseIdHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "recordedAt": { "type": "string" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
