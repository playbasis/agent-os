{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbasis.internal/schemas/router/model-config.schema.json",
  "title": "RouterModelConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "configId", "stageModels"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "configId": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "defaultModelId": { "type": ["string", "null"], "minLength": 1 },
    "stageModels": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "S1": { "type": "string", "minLength": 1 },
        "S2": { "type": "string", "minLength": 1 },
        "S3": { "type": "string", "minLength": 1 },
        "S4": { "type": "string", "minLength": 1 },
        "S5": { "type": "string", "minLength": 1 },
        "S6": { "type": "string", "minLength": 1 },
        "S7": { "type": "string", "minLength": 1 },
        "S8": { "type": "string", "minLength": 1 },
        "S9": { "type": "string", "minLength": 1 }
      }
    },
    "metadata": { "type": "object" }
  }
}
