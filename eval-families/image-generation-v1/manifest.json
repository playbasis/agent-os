    "publicReportsExclude": [
      "raw prompts when private",
      "raw request bodies",
      "raw response bodies",
      "base64 image payloads",
      "private URLs",
      "raw generated images",
      "source photos",
      "private target pixels",
      "env values"
    ],
    "privateEvalRootLabelHash": "82362d873f0f587ac294c14d39d5bdf749303734212f27e16a3e4dac32287538",
    "privateEvalRootLabelIncluded": false
